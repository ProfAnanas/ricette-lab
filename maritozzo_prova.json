{
    "id": "maritozzo_prova",
    "titolo": "Maritozzi",
    "nota_dosi": "per 12-13 porzioni",
    "ingredienti": [
        {
            "quantita": 300,
            "unita_descrizione": "g Farina forte (320W - Manitoba)"
        },
        {
            "quantita": 200,
            "unita_descrizione": "g Farina 00 debole"
        },
        {
            "quantita": 180,
            "unita_descrizione": "g Latte intero (o acqua)"
        },
        {
            "quantita": 100,
            "unita_descrizione": "g Uova intere"
        },
        {
            "quantita": 75,
            "unita_descrizione": "g Zucchero semolato"
        },
        {
            "quantita": 75,
            "unita_descrizione": "g Burro morbido"
        },
        {
            "quantita": 15,
            "unita_descrizione": "g Lievito di birra fresco"
        },
        {
            "quantita": 5,
            "unita_descrizione": "g Sale fino"
        },
        {
            "quantita": null,
            "unita_descrizione": "Aromi a piacere (vaniglia, limone, arancia, ecc.)"
        },
        {
            "quantita": null,
            "unita_descrizione": "Opzionale: per la lucidatura finale"
        },
         {
            "quantita": 100,
            "unita_descrizione": "g Acqua"
        },
         {
            "quantita": 100,
            "unita_descrizione": "g Zucchero"
        }

    ],
    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "In planetaria munita di foglia inserire: burro morbido, zucchero e gli aromi. Impastare a velocità bassa",
            "icona": "foglia",
            "tempo": "2 min.",
            "velocita": "bassa"
        },
        {
            "step_id": "step-2",
            "testo": "Aggiungere le farine e il sale.",
            "icona": "aggiungere",
            "tempo": "2 min.",
            "velocita": "bassa"
        },
        {
            "step_id": "step-3",
            "testo": "Sostituire la foglia con il gancio quindi aggiungere le uova, il latte e il lievito sbriciolato. Impastare a velocità media per 2-3 minuti",
            "icona": "gancio",
            "tempo": "2-3 min.",
            "velocita": "media"
        },
        {
            "step_id": "step-4",
            "testo": "Alzare la velocità (non al massimo) e far lavorare l'impasto per una decina di minuti, fino a incordatura completata.",
            "icona": "gancio",
            "tempo": "10 min.",
            "velocita": "alta"
        },
        {
            "step_id": "step-5",
            "testo": "Trasferire l'impasto in un contenitore leggermente unto e far lievitare fino a triplicare il volume.",
            "icona": "lievitazione",
            "temperatura": "26-28°C",
            "tempo": "2 ore."
        },
        {
            "step_id": "step-6",
            "testo": "Porzionare l'impasto in pezzature di 75-80 g l'una. Quindi trasferirle, ben distanziate tra loro, in una teglia rivestita di carta da forno",
            "icona": "porzionare"
        },
        {
            "step_id": "step-7",
            "testo": "Far lievitare fino a triplicare il volume.",
            "icona": "lievitazione",
            "tempo": "1.30 ora"
        },
        {
            "step_id": "step-8",
            "testo": "Cuocere in forno statico a 200°C per circa 15 minuti.",
            "icona": "forno_statico",
            "temperatura": "200°C",
            "tempo": "15 min."
        },
         {
            "step_id": "step-9",
            "testo": "Ancora bollenti, appena tolti dal forno, spennellare con sciroppo fatto con acqua e zucchero in rapporto 1:1.",
            "icona": "spennellare",
            "opzionale": true
        }
    ]
}