{
    "id": "focaccia_indiretto",
    "titolo": "Focaccia con Poolish (Impasto Indiretto)",
    "nota_dosi": "Per una teglia 30x40 (idratazione 70%)",
    "ingredienti": [
        {
            "quantita": null,
