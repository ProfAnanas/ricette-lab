    "procedimento": [
        {
            "step_id": "step-1",
            "testo": "Preparare la pasta fresca e abbatterla in positivo (sottovuoto o pellicola)",
            "icona": "frigorifero",
            "temperatura": "+4°C"
        },
        {
            "tipo": "parallelo",
            "rami": [
                {
                    "step_id": "step-2a",
                    "testo": "Tagliare le carni a pezzi piccoli tutti uguali",
                    "icona": "tagliare"
                },
                {
                    "step_id": "step-2b",
                    "testo": "Lavare, mondare e tagliare le verdure",
                    "icona": "tagliare"
                }
            ]
        },
        {
            "step_id": "step-3",
            "testo": "Arrostire le carni in padella o casseruola.",
            "icona": "padella"
        },
        {
            "step_id": "step-4",
            "testo": "Aggiungere le verdure e proseguire la cottura fino a che sia la carne che le verdure siano tenere.",
            "icona": "padella"
        },
        {
            "step_id": "step-5",
            "testo": "Abbattere il ripieno in positivo fino a raffreddamento.",
            "temperatura": "+4°C"
        },
        {
            "step_id": "step-6",
            "testo": "Macinare il ripieno e aggiustare il gusto con sale, pepe e formaggio grattugiato.\nTrasferire quindi in sac-a-poche",
            "icona": "mixer"
        },
        {
            "step_id": "step-7",
            "testo": "Stendere la pasta poco alla volta (per evitare che secchi), disporre il ripieno e formare i plin.",
            "icona": "mattarello"
        },
        {
            "step_id": "step-8",
            "testo": "Cuocere i plin in acqua bollente salata.",
            "icona": "pentola_alta",
            "temperatura": "100°C"
        },
        {
            "step_id": "step-9",
            "testo": "Servire con burro emulsionato a caldo, aromatizzato con salvia, sale e formaggio grattugiato.",
